# ─────────────────────────────────────────────────────
#  Promjai-Klaibaan  —  Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────

# Path to SQLite database file.
# For local dev: leave empty (defaults to <project_root>/promjai.db)
# For Docker / Render: set to a path on a persistent volume, e.g. /data/promjai.db
DB_PATH=

# Directory for JSONL event logs.
# For local dev: leave empty (defaults to <project_root>/logs)
# For Docker / Render: /data/logs
LOG_DIR=

# Comma-separated list of allowed CORS origins.
# For local dev both ports are included by default.
# For production set to your actual domain, e.g.:
#   ALLOWED_ORIGINS=https://promjai.example.com
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8001,http://127.0.0.1:8000,http://127.0.0.1:8001

# Token lifetime in hours (default: 24)
TOKEN_TTL_HOURS=24

# Rate limiting: max login attempts per IP per window
RATE_MAX=10
RATE_WINDOW=60

# Maximum items returned by /recommendations
MAX_TOP_K=50
